{
  "name": "Haimiya Pure",
  "description": "Ultra-minimal AMOLED Discord theme built exclusively around a silver-haired waifu aesthetic. No ocean/blue system. Focus is monochrome depth, cinematic contrast, and clean UI framing of background art.",

  "spec": 2,

  "design_identity": {
    "core": "waifu_centric_monochrome",
    "accent_policy": "no_blue_allowed",
    "structure_color": "silver_only",
    "emotion_language": "light_shadow_contrast",
    "inspiration": "anime_portrait_gallery_ui"
  },

  "background": {
    "url": "https://raw.githubusercontent.com/dipup1470-pixel/OceanTheme/main/6193609c-b720-4a6e-a0f2-f0c6dfe0a276-Picsart-AiImageEnhancer.jpeg",
    "blur": 0,
    "dim": 0.74,
    "overlay": "rgba(0,0,0,0.72)",
    "vignette": 0.32
  },

  "colors": {
    "black": "#000000",
    "deep_black": "#050507",
    "surface": "#0A0A0D",
    "surface_soft": "#101015",

    "silver_main": "#D8D8DC",
    "silver_muted": "#A0A3AA",
    "silver_dim": "#6E727A",

    "text_primary": "#F5F6F8",
    "text_secondary": "#C9CDD3",
    "text_muted": "#8A8F98"
  },

  "semanticColors": {
    "BACKGROUND_PRIMARY": "#000000",
    "BACKGROUND_SECONDARY": "#050507",
    "BACKGROUND_TERTIARY": "#0A0A0D",

    "TEXT_NORMAL": "#F5F6F8",
    "TEXT_MUTED": "#8A8F98",

    "TEXT_LINK": "#D8D8DC",

    "INTERACTIVE_NORMAL": "#D8D8DC",
    "INTERACTIVE_HOVER": "#F5F6F8",
    "INTERACTIVE_ACTIVE": "#D8D8DC",

    "CHANNEL_DEFAULT": "#D8D8DC",
    "CHANNEL_SELECTED": "#F5F6F8",
    "CHANNEL_MUTED": "#6E727A"
  },

  "components": {
    "mentions": {
      "background": "rgba(255,255,255,0.06)",
      "border": "#D8D8DC",
      "text": "#F5F6F8"
    },

    "replies": {
      "line": "#D8D8DC",
      "preview": "#A0A3AA"
    },

    "hover": {
      "background": "rgba(255,255,255,0.04)"
    },

    "selected_channel": {
      "background": "rgba(255,255,255,0.05)",
      "indicator": "#D8D8DC"
    },

    "ping_badge": {
      "background": "#F5F6F8",
      "text": "#000000"
    }
  },

  "ui": {
    "glassmorphism": true,
    "glass_strength": 0.38,
    "glass_blur": 12,
    "border_radius": 10,
    "shadow_strength": 0.25
  },

  "icons": {
    "default": "#A0A3AA",
    "active": "#F5F6F8",
    "muted": "#6E727A"
  },

  "rules": {
    "NO_BLUE": true,
    "NO_OCEAN_PALETTE": true,
    "NO_COLOR_ACCENTS_EXCEPT_SILVER": true,
    "BACKGROUND_IS_PRIMARY_ART": true,
    "UI_SHOULD_NOT_COMPETE_WITH_IMAGE": true
  }
}
