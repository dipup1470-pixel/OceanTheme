{
  "name": "Haimiya Premium - Frost Reactive",
  "description": "AMOLED-first waifu-reactive Discord theme. Built from graphite base with silver structural UI and restrained ice-blue interaction system. Designed for clean background dominance and high readability.",

  "spec": 2,

  "design_identity": {
    "base": "true_amoled_black",
    "structure": "silver_layered_ui",
    "accent_logic": "blue_only_for_interaction_signals",
    "avoid": ["blue_overuse", "white_ui_flood", "washed_gray_backgrounds"]
  },

  "background": {
    "url": "https://raw.githubusercontent.com/dipup1470-pixel/OceanTheme/main/6193609c-b720-4a6e-a0f2-f0c6dfe0a276-Picsart-AiImageEnhancer.jpeg",
    "alpha": 0.50,
    "blur": 0,
    "vignette": 0.28,
    "overlay": "rgba(0,0,0,0.72)"
  },

  "colors": {
    "black_0": "#000000",
    "black_1": "#050507",
    "black_2": "#0A0C10",
    "surface": "#0B0D12",
    "surface_elevated": "#10131A",

    "silver_primary": "#D6D6DA",
    "silver_muted": "#AAB0BA",
    "silver_dim": "#6F7782",

    "ice_blue": "#4DA9FF",
    "ice_soft": "#8AB6FF",

    "text_primary": "#F5F8FF",
    "text_muted": "#AAB4C2"
  },

  "semanticColors": {
    "BACKGROUND_PRIMARY": "#050507",
    "BACKGROUND_SECONDARY": "#0A0C10",
    "BACKGROUND_TERTIARY": "#0B0D12",

    "TEXT_NORMAL": "#F5F8FF",
    "TEXT_MUTED": "#AAB4C2",

    "TEXT_LINK": "#4DA9FF",

    "INTERACTIVE_NORMAL": "#D6D6DA",
    "INTERACTIVE_HOVER": "#F5F8FF",
    "INTERACTIVE_ACTIVE": "#4DA9FF",

    "CHANNEL_SELECTED": "#4DA9FF",
    "CHANNEL_DEFAULT": "#D6D6DA",
    "CHANNEL_MUTED": "#6F7782"
  },

  "ui_system": {
    "glassmorphism": true,
    "glass_strength": 0.48,
    "glass_blur": 14,
    "border_radius": 12,

    "shadow_depth": "soft_low",
    "contrast_priority": "text_over_background"
  },

  "components": {
    "mentions": {
      "bg": "rgba(77, 169, 255, 0.10)",
      "border": "#4DA9FF",
      "text": "#F5F8FF"
    },

    "replies": {
      "line": "#4DA9FF",
      "preview": "#AAB0BA"
    },

    "hover": {
      "bg": "rgba(255,255,255,0.04)"
    },

    "selected_channel": {
      "bg": "rgba(214, 214, 218, 0.06)",
      "indicator": "#4DA9FF"
    },

    "ping_badge": {
      "bg": "#4DA9FF",
      "text": "#000000"
    }
  },

  "status": {
    "online": "#8AB6FF",
    "idle": "#F5F8FF",
    "dnd": "#4DA9FF",
    "offline": "#6F7782"
  },

  "icons": {
    "default": "#AAB0BA",
    "active": "#4DA9FF",
    "muted": "#6F7782"
  },

  "rules": {
    "blue_usage": "interaction_only",
    "silver_usage": "ui_structure",
    "background_protection": "strong_dim_not_blur",
    "no_white_ui_flood": true
  }
}
