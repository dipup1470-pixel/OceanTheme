{
  "metadata": {
    "name": "Haimiya Theme :)",
    "author": "SomethingTags",
    "version": "6.7",
    "description": "made by SomethingTags for Vencord",
    "source": "https://github.com/ClearVision/ClearVision-v7",
    "website": "https://clearvision.github.io",
    "invite": "dHaSxn3"
  },
  "imports": [
    "https://clearvision.github.io/ClearVision-v7/main.css",
    "https://clearvision.github.io/ClearVision-v7/betterdiscord.css",
    "https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap"
  ],
  "rootVariables": {
    "--background-image": "url(https://i.imgur.com/zbeHMOO.jpeg)",
    "--main-color": "#d81b60",
    "--hover-color": "#b0134b",
    "--focus-color": "#00e5ff",
    "--channel-unread": "#d81b60",
    "--channel-unread-hover": "#00e5ff"
  },
  "customOverrides": {
    ".leading_c38106::before, [class*=\"leading_\"]::before": {
      "content": "\"Haimiya Senpai Wa Kowakute Kawaii\" !important",
      "font-family": "'Great Vibes', cursive !important",
      "font-size": "18px !important",
      "font-weight": "500 !important",
      "display": "inline-block !important",
      "background": "linear-gradient(90deg, #d81b60, #00e5ff) !important",
      "-webkit-background-clip": "text !important",
      "-webkit-text-fill-color": "transparent !important",
      "filter": "drop-shadow(0 0 2px rgba(216, 27, 96, 0.6)) drop-shadow(0 0 5px rgba(0, 229, 255, 0.4)) !important",
      "visibility": "visible !important"
    },
    ".leading_c38106::after, [class*=\"leading_\"]::after": {
      "content": "\"\" !important",
      "visibility": "visible !important"
    },
    "[class*=\"guilds_\"], [class*=\"guilds_\"] [class*=\"scroller_\"], [class*=\"guilds_\"] [class*=\"tree_\"]": {
      "background": "transparent !important",
      "background-color": "transparent !important"
    },
    "[class*=\"panels_\"], [class*=\"panels_\"] > div, [class*=\"activityPanel_\"], [class*=\"channelTextArea_\"], [class*=\"scrollableContainer_\"], [class*=\"inner_\"]": {
      "background": "transparent !important",
      "background-color": "transparent !important",
      "box-shadow": "none !important",
      "border": "none !important"
    },
    "[class*=\"privateChannels_\"] [class*=\"channel_\"]": {
      "border-bottom": "1px solid !important",
      "border-image": "linear-gradient(to right, transparent, #d81b60 35%, #00e5ff 65%, transparent) 1 !important",
      "box-shadow": "none !important",
      "border-radius": "0 !important",
      "background": "transparent !important"
    },
    "[class*=\"folderIconWrapper_\"], [class*=\"closedFolderIconWrapper_\"]": {
      "box-shadow": "0 0 1px 1px #d81b60, 0 0 3px 1px #00e5ff !important"
    },
    "[class*=\"privateChannels_\"] [class*=\"interactive_\"][class*=\"selected_\"], [class*=\"privateChannels_\"] [class*=\"selected_\"] a[class*=\"link_\"], [class*=\"privateChannels_\"] [class*=\"channel_\"] [class*=\"selected_\"]": {
      "background": "linear-gradient(90deg, #d81b60, #00e5ff) !important"
    }
  }
}
